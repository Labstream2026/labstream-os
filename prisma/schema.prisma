// Labstream OS — esquema base (Fase 0)
// Modelos núcleo: usuarios, roles, permisos, clientes, proyectos.
// Las demás entidades (tareas, entregables, chat, archivos, etc.) se añaden en fases siguientes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Roles y permisos
// ─────────────────────────────────────────────

model Role {
  id          String           @id @default(cuid())
  key         String           @unique // admin, gerente, ventas, productor, ...
  name        String
  description String?
  emoji       String? // icono visible del rol
  color       String? // tono de la paleta (lib/colors) para el chip del rol
  // Rol del sistema (admin y los del seed): no se puede eliminar; admin además es
  // todopoderoso por código. Los roles creados por el admin tienen isSystem=false.
  isSystem    Boolean          @default(false)
  permissions RolePermission[]
  users       User[]
  createdAt   DateTime         @default(now())
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique // ver_proyectos, crear_proyectos, ver_cotizaciones, ...
  description String?
  category    String           @default("General") // agrupación para el panel de roles
  roles       RolePermission[]
}

// Permiso concedido o revocado a un usuario CONCRETO, por encima de su rol.
// Permisos efectivos = (permisos del rol ∪ concedidos) − revocados.
model UserPermission {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  permissionKey String // clave del catálogo (lib/permissions)
  granted       Boolean // true = concedido extra; false = revocado
  createdAt     DateTime @default(now())

  @@unique([userId, permissionKey])
  @@index([userId])
}

model RolePermission {
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId       String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId String

  @@id([roleId, permissionId])
}

// ─────────────────────────────────────────────
// Usuarios
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  title        String? // cargo visible: "Productora", "Editor", ...
  passwordHash String? // se completa en fase 1 (auth real); SSO Authentik mapea por email
  initials     String? // "MR"
  avatarColor  String? // clase/HEX para el avatar
  avatarUrl    String? // foto de perfil subida (opcional)
  active       Boolean   @default(true)
  // Invitado puntual: además de freelancer/cliente, marca a un usuario interno
  // como invitado sin acceso a la Wiki (ni a sus enlaces compartidos).
  isGuest      Boolean   @default(false)
  // Género para el saludo de Marcebot: "M" (muchacho) | "F" (muchacha) | null (neutro).
  gender       String?
  // Datos del colaborador (editables por la persona en su perfil): documento, seguridad
  // social y fecha de nacimiento (la edad se calcula a partir de ella).
  cedula       String?
  eps          String?
  arl          String?
  birthDate    DateTime?
  // WhatsApp: número (E.164, p. ej. +57300...) para RECIBIR notificaciones del bot y para
  // identificar al remitente de mensajes entrantes. `whatsappCommand` = puede COMANDAR al bot
  // por WhatsApp (crear notas/tareas/citas, consultar); si es false solo recibe (no se procesan
  // sus mensajes entrantes). Así el equipo recibe avisos pero no puede darle órdenes al bot.
  whatsappPhone   String?
  whatsappCommand Boolean  @default(false)
  // Usuario de sistema (Marcebot): no inicia sesión y se oculta de los listados.
  isSystemBot  Boolean   @default(false)
  role         Role      @relation(fields: [roleId], references: [id])
  roleId       String
  ledProjects  Project[] @relation("ProjectLead")

  assignedTasks    Task[]               @relation("TaskAssignee")
  ownedTasks       Task[]               @relation("TaskOwner")
  tasksAssignedByMe Task[]              @relation("TaskAssigner")
  ownedDeliverables Deliverable[]       @relation("DeliverableOwner")
  reviewerDeliverables Deliverable[]    @relation("DeliverableReviewer")
  deliverableReviewerOf DeliverableReviewer[] @relation("DeliverableReviewers")
  uploadedFiles    FileAsset[]          @relation("FileUploader")
  uploadedVersions DeliverableVersion[] @relation("VersionUploader")
  chatMessages     ChatMessage[]        @relation("MessageAuthor")
  channelMemberships ChannelMember[]
  projectMemberships ProjectMember[]
  clientMemberships  ClientMember[]
  createdQuotes    Quote[]              @relation("QuoteCreator")
  approvedQuotes   Quote[]              @relation("QuoteApprover")
  createdInvoices  Invoice[]            @relation("InvoiceCreator")
  createdProposals Proposal[]           @relation("ProposalCreator")
  deliverableDecisions DeliverableDecision[] @relation("DecisionAuthor")
  reviewComments   ReviewComment[]      @relation("ReviewCommentAuthor")
  libraryAssets    LibraryAsset[]       @relation("LibraryUploader")
  createdPolls     Poll[]               @relation("PollCreator")
  pollVotes        PollVote[]
  notifications    Notification[]       @relation("NotificationRecipient")
  notificationsActed Notification[]     @relation("NotificationActor")
  clientFiles      ClientFile[]         @relation("ClientFileUploader")
  appKeys          AppKey[]             @relation("AppKeyUser")
  pushSubscriptions PushSubscription[]
  createdEvents    CalendarEvent[]      @relation("EventCreator")
  eventAttendances CalendarAttendee[]
  eventSyncRefs    EventSyncRef[]
  calendarConnection CalendarConnection?
  activity         ActivityLog[]
  messageReactions MessageReaction[]    @relation("ReactionUser")
  ownedCredentials   Credential[]       @relation("CredentialOwner")
  createdCredentials Credential[]       @relation("CredentialCreator")
  credentialViews    CredentialViewer[] @relation("CredViewer")
  notes              Note[]             @relation("NoteCreator")
  whatsappMessages   WhatsappMessage[]
  taskComments       TaskComment[]      @relation("TaskCommentAuthor")
  timeEntries        TimeEntry[]        @relation("TimeEntryUser")
  ownedWikiPages     WikiPage[]         @relation("WikiPageOwner")
  reviewedWikiPages  WikiPage[]         @relation("WikiPageReviewer")
  permissionOverrides UserPermission[]
  preference          UserPreference?
  notifPrefs          UserNotificationPref[]
  myDayItems          MyDayItem[]
  marcebotState      MarcebotState?     @relation("MarcebotStateUser")
  equipPlansAssigned EquipmentPlan[]    @relation("EquipPlanAssignee")
  equipPlansCreated  EquipmentPlan[]    @relation("EquipPlanCreator")
  kitsCreated        EquipmentKit[]     @relation("KitCreator")
  servicePackages    ServicePackage[]   @relation("ServicePackageCreator")
  recurringAssigned  RecurringTask[]    @relation("RecurAssignee")
  recurringCreated   RecurringTask[]    @relation("RecurCreatedBy")

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Preferencias por usuario que SINCRONIZAN entre dispositivos (antes solo vivían en el
// localStorage de cada navegador, así que no pasaban del móvil al escritorio). Fila por
// usuario; todo con defaults sensatos. El layout las hidrata en el servidor (sin parpadeo).
model UserPreference {
  userId           String   @id
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sidebarCollapsed Boolean  @default(false) // barra lateral plegada (modo riel)
  chatPanelOpen    Boolean  @default(true)  // panel de chat de la derecha abierto (escritorio)
  reduceMotion     Boolean  @default(false) // accesibilidad: minimizar animaciones/transiciones
  startPage        String   @default("/")   // a dónde llevar al entrar (Inicio por defecto)
  // Vistas guardadas (filtros con nombre) por superficie. JSON [{surface,id,name,query}].
  // Sincronizan entre dispositivos (antes localStorage en task-filters).
  savedViews       String?
  updatedAt        DateTime @updatedAt
}

// Preferencia PERSONAL de notificación por evento y canal. El usuario decide qué le avisa y
// por dónde (campana in-app, push, correo). Sparse: solo se guarda lo que se desvía del valor
// por defecto (todo activo). Se cruza con el ajuste GLOBAL del admin (NotificationSetting):
// para que algo llegue, debe estar activo a nivel global Y a nivel del usuario.
model UserNotificationPref {
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventKey String // clave del catálogo NOTIFICATION_EVENTS (p. ej. "task_assigned")
  inApp    Boolean @default(true)
  push     Boolean @default(true)
  email    Boolean @default(true)

  @@id([userId, eventKey])
  @@index([userId])
}

// Configuración de Marcebot (fila única "default"), editable por el admin desde
// Configuración → Marcebot: encender/apagar, días laborales y franja horaria.
model MarcebotConfig {
  id        String   @id @default("default")
  enabled   Boolean  @default(true)
  workDays  String   @default("1,2,3,4,5") // días laborales (0=Dom … 6=Sáb)
  startHour Int      @default(7) // primera hora que puede escribir
  lastHour  Int      @default(16) // última hora que escribe (cierre del equipo a las 5)
  updatedAt DateTime @updatedAt
}

// Programación del sondeo de calendarios Synology (fila única "default"), controlada desde
// la app (Configuración → Integraciones). Un planificador en-proceso la lee y sincroniza
// según frecuencia/franja/días — así la app es la fuente principal, sin depender del NAS.
// La hora/días se evalúan en zona horaria de Bogotá (el contenedor corre en UTC).
model CalendarSyncSettings {
  id           String    @id @default("default")
  enabled      Boolean   @default(true)
  everyMinutes Int       @default(15) // cada cuántos minutos sondear
  startHour    Int       @default(8)  // primera hora (inclusive) de la franja activa
  endHour      Int       @default(18) // última hora (exclusiva) de la franja activa
  workDays     String    @default("0,1,2,3,4,5,6") // días activos (0=Dom … 6=Sáb)
  lastRunAt    DateTime? // último sondeo lanzado por el planificador
  updatedAt    DateTime  @updatedAt
}

// Configuración SMTP del envío de correo (fila única "default"), editable por el admin
// desde Configuración → Integraciones. Tiene PRIORIDAD sobre las variables de entorno:
// permite configurar el correo (p. ej. Synology MailPlus) desde la propia app sin tocar
// el .env ni redesplegar. La contraseña se guarda CIFRADA (lib/crypto).
model MailSettings {
  id                 String   @id @default("default")
  enabled            Boolean  @default(false)
  host               String?
  port               Int      @default(587)
  secure             Boolean  @default(false) // true = SSL (465); false = STARTTLS (587)
  username           String?
  passwordEnc        String? // contraseña cifrada (v1:...)
  fromName           String?  @default("Labstream OS")
  fromEmail          String?
  rejectUnauthorized Boolean  @default(false) // MailPlus suele usar certificado autofirmado
  updatedAt          DateTime @updatedAt
}

// Marca/branding de la organización (fila única "default"), editable por el admin en
// Configuración → Marca. `primaryColor` (hex, p. ej. "#2563eb") re-tiñe TODA la app: se inyecta
// como --primary/--ring en el layout raíz. null = usa el azul por defecto de globals.css.
model OrgSettings {
  id           String   @id @default("default")
  primaryColor String? // hex "#rrggbb" o null (color por defecto)
  // Personalización de los estados de proyecto: JSON { CLAVE_ENUM: { label, color } }. Solo
  // sobrescribe etiqueta/color de los estados existentes (no migra el enum). null = por defecto.
  projectStatuses String?
  updatedAt    DateTime @updatedAt
}

// Conexión al agente de IA OpenClaw (gateway autohospedado, API compatible con OpenAI).
// Fila única "default", editable por el admin en Configuración → Integraciones. El token
// Bearer se guarda CIFRADO (lib/crypto). Cuando alguien etiqueta al bot (@Marcebot) en
// cualquier chat, la app reenvía el contexto reciente a baseUrl + "/v1/chat/completions"
// y publica la respuesta del agente como un mensaje del bot.
model OpenClawSettings {
  id         String   @id @default("default")
  enabled    Boolean  @default(false)
  baseUrl    String? // ej. http://192.168.0.4:18789 (sin barra final)
  tokenEnc   String? // token Bearer cifrado (v1:...)
  agentModel String   @default("openclaw") // valor del campo "model" de OpenAI; enruta al agente por defecto
  updatedAt  DateTime @updatedAt
}

// Conexión OAuth a Higgsfield (MCP de imágenes/videos con créditos del PLAN del usuario).
// Fila única "default". El refresh_token se guarda CIFRADO; Higgsfield puede ROTARLO en cada
// refresh → se re-guarda. Se conecta desde Configuración → Integraciones (flujo OAuth+PKCE).
model HiggsfieldAuth {
  id              String    @id @default("default")
  clientId        String? // client_id del registro dinámico OAuth
  refreshTokenEnc String? // refresh_token cifrado (v1:...)
  connectedById   String?
  connectedByName String?
  connectedAt     DateTime?
  updatedAt       DateTime  @updatedAt
}

// Trabajo de generación de medios (video) en Higgsfield, ASÍNCRONO: el video tarda minutos, así
// que la tool generar_video crea el job y responde, y el cron /api/cron/media-jobs lo sondea hasta
// completarlo y publicar el resultado en el chat del que lo pidió.
model MediaJob {
  id            String   @id @default(cuid())
  channelId     String
  userId        String
  kind          String   @default("video") // "video" | "image"
  prompt        String
  provider      String   @default("higgsfield")
  providerJobId String? // id del job en Higgsfield para sondear
  status        String   @default("queued") // queued | in_progress | completed | failed | nsfw
  resultUrl     String?
  error         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
}

// Conexión al Document Server de OnlyOffice (edición colaborativa de documentos). Fila única
// "default", editable por el admin en Configuración → Integraciones. El secreto JWT se guarda
// CIFRADO. Si no hay fila, se cae a las variables de entorno ONLYOFFICE_* (compatibilidad).
model OnlyOfficeSettings {
  id           String   @id @default("default")
  enabled      Boolean  @default(false)
  docsUrl      String? // URL pública del Document Server (la usa el navegador), sin barra final
  jwtSecretEnc String? // secreto JWT compartido con el Document Server, cifrado (v1:...)
  callbackBase String? // la app vista DESDE el contenedor de OnlyOffice (IP LAN del NAS:puerto)
  internalUrl  String? // el Document Server visto DESDE el contenedor de la app (IP LAN:8088)
  updatedAt    DateTime @updatedAt
}

// Interruptor por TIPO de notificación, global para todo el equipo (lo gestiona el admin en
// Configuración → Notificaciones). El catálogo de `key` vive en código (`@/lib/notification-types`);
// aquí solo se guarda lo que se TOCA. Por defecto todo está activo: si no hay fila para un key,
// se considera habilitado. Desactivar un key corta ese aviso (in-app, push y correo).
model NotificationSetting {
  key         String   @id // event key del catálogo (p. ej. "task_assigned")
  enabled     Boolean  @default(true)
  updatedById String? // quién lo cambió por última vez (admin)
  updatedAt   DateTime @updatedAt
}

// Credencial de la API intermedia (/api/v1). Un servicio externo (gateway de OpenClaw, n8n,
// un GPT…) se autentica con `Authorization: Bearer <secreto>`. El secreto NUNCA se guarda en
// claro ni cifrado reversible: solo su hash SHA-256 (una fuga de BD no entrega keys usables);
// el `prefixVisible` (primeros chars) sí es visible para identificarla en UI y logs.
// La key se ata a un USUARIO del que hereda permisos EN VIVO; los permisos efectivos de la
// petición = intersección(permisos del usuario, `scopes`). Si el usuario se desactiva, la key
// queda inerte automáticamente (buildAgentSession devuelve null).
model AppKey {
  id              String    @id @default(cuid())
  name            String // etiqueta humana (ej. "Gateway OpenClaw")
  prefixVisible   String    @unique // ej. "lsk_a1b2c3d4" — visible, NO secreto
  secretHash      String // sha256(secretoCompleto) en hex — verificación, nunca recuperación
  scopes          String[]  @default([]) // subconjunto de ALL_PERMISSION_KEYS; [] = todos los del usuario
  readOnly        Boolean   @default(false) // true = solo herramientas/endpoints de consulta
  user            User      @relation("AppKeyUser", fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  createdById     String? // admin que la creó
  rateLimitPerMin Int       @default(120)
  lastUsedAt      DateTime?
  lastUsedIp      String?
  expiresAt       DateTime? // null = sin caducidad
  revoked         Boolean   @default(false)
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([revoked])
}

// Estado de Marcebot por usuario: evita repetir el mismo resumen cada hora (anti-spam)
// y recuerda si ya envió el saludo del día (personal y, para roles administrativos,
// el resumen de equipo).
model MarcebotState {
  userId         String    @id
  user           User      @relation("MarcebotStateUser", fields: [userId], references: [id], onDelete: Cascade)
  lastDigest     String? // hash del último DM personal enviado
  lastSentAt     DateTime?
  lastMorningOn  String? // "YYYY-MM-DD" (Colombia) del último saludo matutino personal
  lastTeamDigest String? // hash del último DM de resumen de equipo
  lastTeamOn     String? // "YYYY-MM-DD" del último resumen de equipo
  lastWeeklyOn   String? // "YYYY-MM-DD" del último cierre de semana (viernes)
  updatedAt      DateTime  @updatedAt
}

// Registro de actividad: cada cambio relevante queda con su fecha/hora y autor.
model ActivityLog {
  id         String   @id @default(cuid())
  action     String // "task.create", "task.stage", "task.status", "file.upload", ...
  summary    String // descripción legible: «movió "Grabación" a Producción»
  entityType String? // "task" | "deliverable" | "file" | "member" | "project" | "client" | "table"
  entityId   String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String?
  client     Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId   String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId     String?
  actorName  String? // nombre del autor sin cuenta (p. ej. el cliente desde el portal público)
  createdAt  DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([clientId, createdAt])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// Clientes
// ─────────────────────────────────────────────

model Client {
  id          String    @id @default(cuid())
  name        String
  company     String?
  description String? // "Productora audiovisual · 2 proyectos"
  emoji       String? // 🎬 🌐 ☀️ 🟠
  accentColor String? // color del cliente: tiñe su cabecera y sus proyectos (como las tareas)
  bannerUrl   String? // portada/banner tipo Notion (imagen subida, servida por /api/banner)
  photoUrl    String? // foto del cliente (subida), servida por /api/client-asset/photo/<id>
  logoUrl     String? // logo del cliente (PNG subido), servido por /api/client-asset/logo/<id>
  logoBg      String? // color de fondo del recuadro del logo (hex) para PNG con transparencia
  notes       String?
  projects    Project[]
  quotes      Quote[]
  invoices    Invoice[]
  proposals   Proposal[]
  activity    ActivityLog[]
  channel     ChatChannel?
  members     ClientMember[]
  files       ClientFile[]
  clientNotes Note[] // notas (modelo Note) etiquetadas a este cliente — distinto del campo `notes` libre
  // Activo/inactivo: un cliente sin proyectos a la vista se DESACTIVA para no estorbar en
  // las listas, y se REACTIVA cuando llega un proyecto nuevo. Distinto de archivar: el
  // inactivo NO va a la papelera, solo se oculta de las listas activas (con filtro para verlo).
  isActive    Boolean   @default(true)
  // Archivado (borrado suave): en vez de BORRAR un cliente —lo que arrastraría sus
  // facturas/cotizaciones/proyectos— se archiva. Sale de las listas pero se puede
  // RESTAURAR; nada de su información se elimina. Solo admins archivan/restauran.
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([archivedAt])
}

// Quién puede VER un cliente. Los admin ven todos; el resto solo los clientes
// donde es miembro explícito o donde participa en algún proyecto del cliente.
model ClientMember {
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@id([clientId, userId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// Proyectos
// ─────────────────────────────────────────────

enum ProjectStatus {
  NUEVO
  EN_PLANEACION
  EN_PREPRODUCCION
  EN_PRODUCCION
  EN_EDICION
  REVISION_INTERNA
  REVISION_CLIENTE
  CORRECCIONES
  APROBADO
  ENTREGADO
  CERRADO
  PAUSADO
  CANCELADO
}

enum ProjectType {
  REEL
  PODCAST
  DOCUMENTAL
  STREAMING
  CURSO
  PUBLICIDAD
  EVENTO
  CORPORATIVO
  INSTITUCIONAL
  FOTOGRAFIA
  CAMPANA_MENSUAL
}

// Estados y prioridades de tarea personalizables por el equipo (con color de la
// paleta de 20 tonos). El valor que guardan Task.status / Task.priority es la `key`.
enum WorkflowLabelKind {
  TASK_STATUS
  TASK_PRIORITY
}

model WorkflowLabel {
  id        String            @id @default(cuid())
  kind      WorkflowLabelKind
  key       String // clave estable que guarda la tarea (ej. PENDIENTE, ALTA o custom-xxxx)
  label     String // nombre visible, editable
  color     String            @default("slate") // tono de lib/colors
  position  Int               @default(0)
  isDefault Boolean           @default(false) // valor por defecto al crear tarea
  isDone    Boolean           @default(false) // marca "terminado" (solo estados) para "Mis tareas"
  createdAt DateTime          @default(now())

  @@unique([kind, key])
  @@index([kind, position])
}

model Project {
  id          String        @id @default(cuid())
  code        String        @unique // LS-0001
  name        String
  description String?
  type        ProjectType   @default(REEL)
  status      ProjectStatus @default(NUEVO)
  priority    String        @default("MEDIA")
  progress    Int           @default(0) // 0-100
  emoji       String?
  startDate   DateTime?
  dueDate     DateTime?
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  lead        User?         @relation("ProjectLead", fields: [leadId], references: [id])
  leadId      String?
  templateKey String? // plantilla de origen, si se creó desde una
  color       String? // color del proyecto (para el calendario de entregables)
  bannerUrl   String? // portada/banner tipo Notion (imagen subida, servida por /api/banner)
  // Proyecto compartido (estilo Mattermost): público = visible a todo el equipo
  // con permiso ver_proyectos; privado = solo responsable + miembros + admin.
  // Por defecto PRIVADO: un usuario nuevo arranca sin proyectos hasta que lo
  // añaden o el responsable marca el proyecto como público.
  isPrivate   Boolean       @default(true)
  // Columnas del tablero de tareas = fases de producción audiovisual (personalizables).
  stages      String[]      @default(["Preproducción", "Producción", "Postproducción", "Revisión cliente", "Entregado"])
  stageColors Json? // mapa fase → tono de color (opcional), para colorear columnas
  // Brief de la PROPUESTA para el equipo (lo que se va a hacer + entregables/compromisos).
  // Visible para todo el equipo del proyecto; NO incluye valores ni equipos. Editable.
  briefScope        String?
  briefDeliverables String?

  tasks          Task[]
  recurringTasks RecurringTask[]
  deliverables Deliverable[]
  folders      ProjectFolder[]
  files        FileAsset[]
  channel      ChatChannel?
  events       CalendarEvent[]
  tables       DataTable[]
  members      ProjectMember[]
  quotes       Quote[]
  invoices     Invoice[]
  activity     ActivityLog[]
  equipmentPlans EquipmentPlan[]
  notes        Note[]

  // Borrado SUAVE (papelera): archivar saca el proyecto de las listas pero conserva todo
  // (tareas, archivos, entregables, chat) y se puede RESTAURAR. No hay borrado físico.
  archivedAt  DateTime?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([archivedAt])
}

// Nota rápida del equipo: una idea, recordatorio o apunte. Se puede crear desde la app, el
// chat (Marcebot) o WhatsApp (campo `source`). Opcionalmente se ancla a un proyecto y/o lleva
// una categoría libre detectada del texto. Es del creador (cada quien ve y gestiona las suyas;
// los admins las ven todas, igual que con otras entidades).
model Note {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String? // categoría libre opcional (p. ej. "presupuesto", "idea")
  pinned      Boolean  @default(false) // fijada arriba de la lista
  source      String   @default("app") // app | chat | whatsapp
  createdBy   User     @relation("NoteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdById String
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId   String?
  // Cliente vinculado (opcional): permite etiquetar y AGRUPAR las notas por cliente sin
  // depender de un proyecto. Independiente de `projectId` (una nota puede tener cliente
  // pero ningún proyecto). Tag visible en el editor y encabezado de grupo en la lista.
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId    String?
  // Color de la nota (clave de paleta, p. ej. "amber"); null = sin color.
  color       String?
  // Visibilidad: "private" (solo el dueño), "project" (miembros del proyecto vinculado) o
  // "team" (todo el equipo). Las compartidas se ven en SOLO LECTURA para quien no es dueño.
  visibility  String   @default("private")
  // Recordatorio: cuándo avisar (remindAt) y cuándo ya se notificó (reminderSentAt, para no
  // repetir). El cron /api/cron/note-reminders dispara los vencidos.
  remindAt       DateTime?
  reminderSentAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
  @@index([projectId])
  @@index([clientId])
  @@index([visibility])
  @@index([remindAt])
}

// Conversación de WhatsApp con el agente (sesión SEPARADA del chat interno). Guarda cada turno
// (user/assistant) para: (1) contexto multi-turno → confirmaciones de acciones sensibles,
// (2) idempotencia por `waMessageId` (único; si el webhook reenvía el mismo mensaje, no se
// reprocesa), (3) trazabilidad de lo que entra/sale por WhatsApp.
model WhatsappMessage {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  role        String // "user" | "assistant"
  content     String
  waMessageId String?  @unique // id del mensaje entrante de WhatsApp (dedupe); null en respuestas
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

// Rol dentro de un proyecto compartido (estilo Mattermost):
// OWNER gestiona el proyecto y sus miembros; MEMBER colabora; GUEST acceso limitado.
enum ProjectRole {
  OWNER
  MEMBER
  GUEST
}

model ProjectMember {
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      ProjectRole @default(MEMBER)
  createdAt DateTime    @default(now())

  @@id([projectId, userId])
}

// ─────────────────────────────────────────────
// Cotizaciones (fase 4)
// ─────────────────────────────────────────────

enum QuoteStatus {
  BORRADOR
  ENVIADA
  APROBADA
  RECHAZADA
}

model Quote {
  id           String      @id @default(cuid())
  code         String      @unique // COT-0001
  title        String
  status       QuoteStatus @default(BORRADOR)
  currency     String      @default("COP")
  taxRate      Int         @default(0) // % IVA (0-100)
  notes        String?
  // Personalización de la carta/PDF (estilo "Desglose"): destinatario y texto editables.
  recipientName String?    // Persona de contacto (línea bajo la empresa)
  recipientCity String?    // Ciudad del destinatario (por defecto "Ciudad")
  intro         String?    // Texto de introducción (si vacío, se genera uno por defecto)
  // Alcance ("qué se va a hacer") y entregables ("qué recibe el cliente"): se muestran en
  // la carta para que el cliente entienda el servicio. También alimentan el brief del proyecto.
  scope         String?
  deliverables  String?
  // Imprevisto OCULTO al cliente (% sobre el subtotal). Se inicializa desde QuoteSettings al
  // crear; el cliente nunca ve esta línea, solo los valores ya ajustados + IVA + total.
  contingencyPct Float     @default(0)
  validUntil   DateTime?
  client       Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId     String
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId    String?
  createdBy    User?       @relation("QuoteCreator", fields: [createdById], references: [id])
  createdById  String?
  approvedBy   User?       @relation("QuoteApprover", fields: [approvedById], references: [id])
  approvedById String?
  approvedAt   DateTime?
  // Decisión del CLIENTE en el portal público, SEPARADA del estado interno: que el cliente
  // "acepte" NO aprueba la cotización. La aprobación interna (status=APROBADA, con permiso
  // aprobar_cotizaciones) es la única que dispara inmutabilidad + facturación.
  clientDecision  String?    // "ACEPTADA" | "RECHAZADA" | null
  clientDecidedAt DateTime?
  items        QuoteItem[]
  invoices     Invoice[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model QuoteItem {
  id          String  @id @default(cuid())
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId     String
  section     String? // agrupa el ítem en una sección del desglose (Preproducción, Rodaje…)
  description String
  unit        String? // unidad de cobro: día | hora | minuto | unidad | evento | servicio…
  quantity    Float   @default(1)
  unitPrice   Float   @default(0)
  // Ítem del catálogo del que salió (trazabilidad; no es relación dura para no acoplar).
  catalogItemId String?
  position    Int     @default(0)

  @@index([quoteId])
}

// Catálogo INTERNO de servicios de Labstream (lista de precios estandarizada). NO se
// muestra al cliente: sirve para armar nuestros costos. Agrupado por tipo de servicio
// (streaming, video_institucional…) y sección (Equipo, Equipo humano…).
model ServiceItem {
  id          String   @id @default(cuid())
  serviceType String   // streaming | video_institucional | contenido_empresa | ...
  section     String   // Equipo técnico | Equipo humano | Postproducción | Logística...
  name        String   // p. ej. "Mezclador de video", "Camarógrafo"
  detail      String?  // aclaración opcional
  unit        String   @default("servicio") // servicio | día | hora | unidad | mes...
  qty         Float    @default(1)   // cantidad sugerida por defecto
  unitPrice   Float    @default(0)   // COSTO interno unitario (COP)
  position    Int      @default(0)
  active      Boolean  @default(true)
  packageItems ServicePackageItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([serviceType])
}

// Paquete/preset reutilizable: una composición con nombre (ej. "Cubrimiento fotográfico
// día completo") = conjunto de ítems del catálogo con su cantidad. Se aplica de un clic
// en una cotización para precargar las líneas.
model ServicePackage {
  id          String               @id @default(cuid())
  name        String               @unique
  emoji       String?
  serviceType String? // tipo de servicio asociado (para filtrar/sugerir)
  description String?
  items       ServicePackageItem[]
  createdBy   User?                @relation("ServicePackageCreator", fields: [createdById], references: [id])
  createdById String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model ServicePackageItem {
  id          String         @id @default(cuid())
  package     ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId   String
  serviceItem ServiceItem    @relation(fields: [serviceItemId], references: [id], onDelete: Cascade)
  serviceItemId String
  quantity    Float          @default(1)

  @@unique([packageId, serviceItemId])
  @@index([serviceItemId])
}

// Ajustes globales de cotización (fila única id="default"): % de transporte/imprevistos
// e IVA por defecto que alimentan el armado interno de costos.
model QuoteSettings {
  id               String   @id @default("default")
  iva              Int      @default(19)   // % IVA
  contingencyPct   Float    @default(10)   // % transporte e imprevistos (sobre el subtotal interno)
  contingencyLabel String   @default("Transporte e imprevistos")
  updatedAt        DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Facturación (Factura = snapshot de una cotización aprobada + estado de cobro)
// ─────────────────────────────────────────────
enum InvoiceStatus {
  BORRADOR // creada, aún no enviada
  ENVIADA // enviada al cliente, pendiente de cobro
  PAGADA // cobrada
  VENCIDA // pasó su fecha de vencimiento sin pagar
  ANULADA // anulada/cancelada
}

model Invoice {
  id          String        @id @default(cuid())
  code        String        @unique // FAC-0001
  status      InvoiceStatus @default(BORRADOR)
  currency    String        @default("COP")
  taxRate     Int           @default(0) // % IVA copiado de la cotización
  notes       String?
  issueDate   DateTime      @default(now())
  dueDate     DateTime? // vencimiento del pago
  paidAt      DateTime? // cuándo se marcó pagada
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  project     Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId   String?
  quote       Quote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  quoteId     String?
  createdBy   User?         @relation("InvoiceCreator", fields: [createdById], references: [id])
  createdById String?
  items       InvoiceItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([clientId])
  @@index([status])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId   String
  section     String?
  description String
  quantity    Float   @default(1)
  unitPrice   Float   @default(0)
  position    Int     @default(0)

  @@index([invoiceId])
}

// Propuestas interactivas (constructor por bloques + asistente).
// A diferencia de la cotización simple (Quote), una propuesta es un documento
// editable hecho de bloques (portada, textos, plan, calendario, inversión, …).
enum ProposalStatus {
  BORRADOR
  ENVIADA
  ACEPTADA
  VENCIDA
}

model Proposal {
  id          String         @id @default(cuid())
  code        String         @unique // PROP-0001
  templateKey String // plantilla que la generó
  title       String
  status      ProposalStatus @default(BORRADOR)
  expiresAt   DateTime? // fecha de validez → deriva "VENCIDA"
  views       Int            @default(0) // se incrementa al abrir el enlace del cliente
  answers     Json? // respuestas del asistente (regeneración / referencia)
  brand       Json // snapshot de marca (empresa, acento, contacto)
  blocks      Json // lista ordenada de bloques del documento
  client      Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId    String?
  createdBy   User?          @relation("ProposalCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([clientId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// Chat
// ─────────────────────────────────────────────

enum ChannelType {
  PROJECT
  CLIENT // chat del cliente: reúne a todos los que trabajan en sus proyectos
  GENERAL
  DIRECT
}

model ChatChannel {
  id        String          @id @default(cuid())
  type      ChannelType     @default(GENERAL)
  name      String
  slug      String?         @unique // canales generales: "general", "estados-equipo"
  isPublic  Boolean         @default(true) // público a todo el equipo o solo a invitados
  project   Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String?         @unique // un canal por proyecto
  client    Client?         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String?         @unique // un canal por cliente
  messages  ChatMessage[]
  members   ChannelMember[]
  polls     Poll[]
  createdAt DateTime        @default(now())
}

// Rol dentro de un canal (estilo Mattermost): ADMIN gestiona el canal
// (visibilidad/miembros), MEMBER solo participa.
enum ChannelRole {
  ADMIN
  MEMBER
}

model ChannelMember {
  channel    ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId  String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  role       ChannelRole @default(MEMBER)
  lastReadAt DateTime? // última vez que el usuario abrió el canal (para no leídos)
  // Silenciado por ESTE usuario: deja de recibir avisos de mensajes nuevos del canal. Las
  // menciones directas (@) SÍ siguen llegando (igual que en Slack). No afecta a otros miembros.
  muted      Boolean     @default(false)
  createdAt  DateTime    @default(now())

  @@id([channelId, userId])
  @@index([userId])
}

model ChatMessage {
  id          String              @id @default(cuid())
  body        String
  channel     ChatChannel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId   String
  author      User?               @relation("MessageAuthor", fields: [authorId], references: [id])
  authorId    String?
  // SetNull (no Cascade): si un mensaje padre se elimina en duro, sus respuestas se
  // conservan (se vuelven de nivel superior) en vez de borrarse, acorde al borrado suave
  // y la auditoría del chat.
  parent      ChatMessage?        @relation("Thread", fields: [parentId], references: [id], onDelete: SetNull)
  parentId    String? // si está, es respuesta dentro de un hilo
  replies     ChatMessage[]       @relation("Thread")
  attachments MessageAttachment[]
  reactions   MessageReaction[]
  poll        Poll?
  pinned      Boolean             @default(false) // mensaje fijado en el canal
  editedAt    DateTime? // se rellena al editar el mensaje
  // Borrado suave: el mensaje desaparece para los usuarios, pero el administrador
  // lo sigue viendo (en gris) para auditoría/seguimiento. No se elimina la fila.
  deletedAt   DateTime?
  deletedById String?
  createdAt   DateTime            @default(now())

  @@index([channelId, createdAt])
  @@index([parentId])
}

// Reacción con emoji a un mensaje (un usuario puede poner varios emojis distintos).
model MessageReaction {
  id        String      @id @default(cuid())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String
  user      User        @relation("ReactionUser", fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String
  createdAt DateTime    @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model MessageAttachment {
  id        String      @id @default(cuid())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String
  name      String
  path      String // ruta relativa dentro del storage
  mime      String?
  size      Int?
  version   Int         @default(1) // se incrementa al guardar desde OnlyOffice (doc key)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Poll {
  id          String       @id @default(cuid())
  question    String
  channel     ChatChannel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId   String
  message     ChatMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId   String?      @unique
  createdBy   User?        @relation("PollCreator", fields: [createdById], references: [id])
  createdById String?
  options     PollOption[]
  votes       PollVote[]
  createdAt   DateTime     @default(now())
}

model PollOption {
  id       String     @id @default(cuid())
  poll     Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollId   String
  text     String
  position Int        @default(0)
  votes    PollVote[]
}

model PollVote {
  id       String     @id @default(cuid())
  poll     Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollId   String
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  optionId String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String

  @@unique([pollId, userId])
}

// ─────────────────────────────────────────────
// Notificaciones (fase 4)
// ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  // Quién ORIGINÓ la notificación (el actor): para agrupar por persona y mostrar su color/avatar
  // en la campana. NULL = evento del sistema (recordatorios, recurrentes, Marcebot). Si el actor
  // se borra, queda NULL (no se pierde la notificación del destinatario).
  actor     User?    @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorId   String?
  type      String // mention, event, task, etc.
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([actorId])
}

// Suscripción de Web Push (navegador) de un usuario, por dispositivo/navegador.
// Permite enviarle notificaciones nativas aunque la pestaña esté en segundo plano.
model PushSubscription {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────
// Calendario (fase 4)
// ─────────────────────────────────────────────

model CalendarEvent {
  id          String             @id @default(cuid())
  title       String
  description String?
  start       DateTime
  end         DateTime?
  allDay      Boolean            @default(false)
  location    String?
  project     Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId   String?
  createdBy   User?              @relation("EventCreator", fields: [createdById], references: [id])
  createdById String?
  attendees   CalendarAttendee[]
  // ── Sincronización con Synology Calendar (CalDAV) ──
  // uid iCalendar estable (mismo en app y en Synology) para casar ida/vuelta.
  uid         String?            @unique
  // Origen del evento: "app" (creado aquí) o "synology" (importado del NAS).
  source      String             @default("app")
  // Última vez que se sincronizó (push o pull) — para diagnóstico.
  syncedAt    DateTime?
  externalRefs EventSyncRef[]
  guests      EventGuest[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt @default(now())

  @@index([start])
  @@index([projectId])
}

model CalendarAttendee {
  event   CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  // Respuesta a la invitación (RSVP): PENDING | ACCEPTED | DECLINED | TENTATIVE.
  status  String        @default("PENDING")

  @@id([eventId, userId])
  @@index([userId])
}

// Copia de un evento en la colección CalDAV de UN usuario (cada asistente tiene la
// suya, con su propio href y etag). Permite actualizar/borrar idempotente y detectar
// cambios desde Synology (pull) por etag.
model EventSyncRef {
  id      String        @id @default(cuid())
  event   CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  href    String // ruta del .ics dentro de la colección del usuario
  etag    String? // etag devuelto por el servidor (control de cambios)

  @@unique([eventId, userId])
  @@index([userId])
}

// Invitado EXTERNO a un evento (no es usuario de la app): cliente, proveedor, etc.
// Se le envía la invitación .ics por correo y aparece como ATTENDEE en el evento.
model EventGuest {
  id      String        @id @default(cuid())
  event   CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String
  email   String
  name    String?

  @@unique([eventId, email])
  @@index([eventId])
}

// Conexión CalDAV de un usuario con su Synology Calendar. Credenciales cifradas
// (AES-256-GCM). El sondeo (pull) usa syncToken para traer solo lo que cambió.
model CalendarConnection {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String    @unique
  // URL base del servidor CalDAV del NAS (p. ej. https://nas:5001).
  serverUrl   String
  username    String
  // Contraseña de aplicación DSM cifrada (nunca en claro).
  passwordEnc String
  // Colección de calendario elegida (href absoluto) donde escribimos/leemos.
  calendarUrl String?
  calendarName String?
  // Token de sincronización incremental (sync-collection REPORT).
  syncToken   String?
  enabled     Boolean   @default(true)
  lastSyncAt  DateTime?
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─────────────────────────────────────────────
// Tablas tipo Notion (fase 4)
// ─────────────────────────────────────────────

enum ColumnType {
  TEXT
  NUMBER
  SELECT // estado / etiqueta
  MULTISELECT // varias etiquetas
  DATE
  PERSON // mención a una persona
  CHECKBOX
  URL
  EVENT // cita de calendario que se envía al asignado
  PASSWORD // oculto hasta hacer clic (contraseñas/secretos del equipo)
  IMAGE // foto/captura subida
  LONGTEXT // texto largo / notas
}

model WikiPage {
  id        String      @id @default(cuid())
  title     String      @default("Página sin título")
  icon      String? // emoji
  content   String      @default("") // markdown / texto
  // Organización: sección (categoría plana) y etiquetas para buscar/filtrar.
  section   String? // "Procesos", "Equipo y técnica", "Clientes", "Administración", "Onboarding"…
  tags      String[]    @default([])
  // Plantilla con la que se creó (SOP, política, ficha…), para saber su tipo.
  templateKey String?
  // Gobernanza: dueño responsable + última revisión (para detectar contenido obsoleto).
  owner          User?    @relation("WikiPageOwner", fields: [ownerId], references: [id])
  ownerId        String?
  lastReviewedBy User?    @relation("WikiPageReviewer", fields: [lastReviewedById], references: [id])
  lastReviewedById String?
  lastReviewedAt DateTime?
  parent    WikiPage?   @relation("WikiTree", fields: [parentId], references: [id], onDelete: SetNull)
  parentId  String?
  children  WikiPage[]  @relation("WikiTree")
  tables    DataTable[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([section])
}

model DataTable {
  id         String       @id @default(cuid())
  name       String
  key        String?      @unique // tablas globales únicas de la wiki (ej. "sys:inventario")
  project    Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String?
  wikiPage   WikiPage?    @relation(fields: [wikiPageId], references: [id], onDelete: Cascade)
  wikiPageId String?
  columns    DataColumn[]
  rows       DataRow[]
  createdAt  DateTime     @default(now())
}

model DataColumn {
  id       String     @id @default(cuid())
  table    DataTable  @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tableId  String
  name     String
  type     ColumnType @default(TEXT)
  options  Json? // para SELECT: [{label, color}]
  position Int        @default(0)
  cells    DataCell[]
}

model DataRow {
  id       String     @id @default(cuid())
  table    DataTable  @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tableId  String
  position Int        @default(0)
  cells    DataCell[]
  // Cuando esta fila es un equipo del inventario (tabla sys:inventario), puede pertenecer
  // a kits guardados y estar reservada en planes de equipo de proyectos.
  kitItems     EquipmentKitItem[]
  reservations EquipmentReservation[]
  createdAt DateTime  @default(now())

  @@index([tableId, position])
}

model DataCell {
  id       String     @id @default(cuid())
  row      DataRow    @relation(fields: [rowId], references: [id], onDelete: Cascade)
  rowId    String
  column   DataColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  columnId String
  value    Json? // texto, número, optionId, fecha ISO, userId, {eventId,...}

  @@unique([rowId, columnId])
}

// ─────────────────────────────────────────────
// Usuarios y contraseñas (bóveda de la Wiki, con permisos por credencial)
// ─────────────────────────────────────────────
// La contraseña se guarda cifrada (AES-256-GCM, igual que las celdas PASSWORD).
// Quién puede REVELARla: administradores siempre, el creador, y los usuarios de
// la lista `viewers`. El "dueño" (ownerUser) es solo una etiqueta (de quién es la
// cuenta) y NO implica que pueda verla.
model Credential {
  id          String             @id @default(cuid())
  title       String // ej. "Correo Jaime", "Instagram Labstream"
  category    String? // agrupa: correo, redes, hosting, software…
  username    String? // usuario / correo de acceso
  secretEnc   String // contraseña cifrada
  url         String? // enlace de inicio de sesión
  notes       String?
  ownerUser   User?              @relation("CredentialOwner", fields: [ownerUserId], references: [id])
  ownerUserId String?
  createdBy   User?              @relation("CredentialCreator", fields: [createdById], references: [id])
  createdById String?
  viewers     CredentialViewer[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([category])
}

model CredentialViewer {
  credential   Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  credentialId String
  user         User       @relation("CredViewer", fields: [userId], references: [id], onDelete: Cascade)
  userId       String

  @@id([credentialId, userId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// Tareas
// ─────────────────────────────────────────────

enum RecurrenceFreq {
  DAILY
  WEEKLY
  MONTHLY
}

// Plantilla de tarea recurrente. El cron /api/cron/recurring-tasks crea una Task cada vez que
// toca según la regla (frequency × interval; weekdays para semanal, dayOfMonth para mensual).
// La pueden crear personas del equipo o @Marcebot (agente OpenClaw) en nombre de quien lo pide.
model RecurringTask {
  id            String         @id @default(cuid())
  title         String
  description   String?
  priority      String         @default("MEDIA")
  isPrivate     Boolean        @default(false)
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String?
  assignee      User?          @relation("RecurAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId    String?
  createdBy     User?          @relation("RecurCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById   String?
  frequency     RecurrenceFreq
  interval      Int            @default(1) // cada N días/semanas/meses
  weekdays      String? // WEEKLY: días "0..6" coma-separados (0=Dom). null = el día de startDate
  dayOfMonth    Int? // MONTHLY: día del mes 1..31. null = el día de startDate
  dueOffsetDays Int            @default(0) // la instancia vence N días después de crearse
  startDate     DateTime // primera fecha en que aplica
  endDate       DateTime? // última fecha (opcional)
  active        Boolean        @default(true)
  lastCreatedOn String? // "YYYY-MM-DD" de la última instancia creada (anti-duplicado del cron)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([active])
  @@index([projectId])
}

model Task {
  id            String          @id @default(cuid())
  title         String
  description   String?
  status        String          @default("PENDIENTE")
  stage         String? // columna del tablero (fase de producción); null = primera columna
  priority      String          @default("MEDIA")
  // Inicio planificado: con dueDate define la barra del cronograma (Gantt). Si solo hay
  // dueDate, la tarea se dibuja como hito de un día; si solo hay startDate, igual.
  startDate     DateTime?
  dueDate       DateTime?
  // Hora de finalización opcional ("HH:mm", hora de pared). Con ella la tarea aparece en el
  // calendario a esa hora (no "todo el día"). Sin ella, sigue siendo de día completo.
  dueTime       String?
  shootDate     DateTime? // fecha de rodaje/grabación (campo de producción)
  // Horas estimadas de trabajo (en minutos, para evitar floats). Alimenta el seguimiento
  // estimado vs real del cronograma. El tiempo real se registra en TimeEntry.
  estimatedMinutes Int?
  // Cuándo se marcó como terminada (estado isDone). Conserva la primera marca y se
  // borra si la tarea vuelve a un estado abierto. Permite listar "Completadas".
  completedAt   DateTime?
  position      Int             @default(0)
  // projectId opcional: las tareas personales/sueltas (ej. "limpiar escritorio") no
  // pertenecen a un proyecto. Las de proyecto sí lo tienen.
  project       Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String?
  deliverable   Deliverable?    @relation(fields: [deliverableId], references: [id], onDelete: SetNull)
  deliverableId String?
  assignee      User?           @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assigneeId    String?
  // Quién creó la tarea (dueño) y quién la asignó por última vez (para "quién me la asignó").
  owner         User?           @relation("TaskOwner", fields: [ownerId], references: [id])
  ownerId       String?
  assignedBy    User?           @relation("TaskAssigner", fields: [assignedById], references: [id])
  assignedById  String?
  // Tarea privada: solo la ve su dueño y su responsable (no todo el equipo).
  isPrivate     Boolean         @default(false)
  checklist     ChecklistItem[]
  comments      TaskComment[]
  timeEntries   TimeEntry[]
  myDayItems    MyDayItem[]
  // Si esta tarea es el "espejo" de un plan de equipo (preparar equipos para una grabación).
  equipmentPlan EquipmentPlan?  @relation("EquipPlanTask")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([projectId])
  @@index([assigneeId])
  @@index([deliverableId])
  @@index([completedAt])
  // El cronograma (por proyecto y global) filtra/ordena tareas por fechas.
  @@index([dueDate])
  @@index([startDate])
  // Rutas calientes: home, mis-tareas y conteos del layout filtran por estado;
  // marcebot/producción filtran por fecha de rodaje.
  @@index([status])
  @@index([shootDate])
}

// Registro de tiempo real trabajado en una tarea (parte de horas). La suma por tarea
// y por proyecto se compara contra `Task.estimatedMinutes` en el cronograma.
model TimeEntry {
  id        String   @id @default(cuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  // Quién imputó las horas. SetNull para conservar el registro si se borra el usuario.
  user      User?    @relation("TimeEntryUser", fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  minutes   Int // duración imputada (minutos)
  note      String? // descripción opcional de lo trabajado
  spentOn   DateTime // día al que se imputa el tiempo (anclado a mediodía UTC)
  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([userId])
  @@index([spentOn])
}

// Comentario/nota en una tarea (hilo de conversación de la tarea).
model TaskComment {
  id        String   @id @default(cuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  author    User?    @relation("TaskCommentAuthor", fields: [authorId], references: [id])
  authorId  String?
  body      String
  createdAt DateTime @default(now())

  @@index([taskId, createdAt])
}

model ChecklistItem {
  id       String  @id @default(cuid())
  label    String
  done     Boolean @default(false)
  position Int     @default(0)
  task     Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId   String
}

// ─────────────────────────────────────────────
// Entregables y versiones
// ─────────────────────────────────────────────

enum DeliverableType {
  REEL
  SHORT
  VIDEO_LARGO
  FOTOGRAFIA
  PODCAST
  TEASER
  DOCUMENTO
  OTRO
}

enum DeliverableStatus {
  PENDIENTE
  EN_PRODUCCION
  EN_EDICION
  REVISION_INTERNA
  ENVIADO_CLIENTE
  CORRECCIONES
  APROBADO
  ENTREGADO
}

model Deliverable {
  id        String               @id @default(cuid())
  name      String
  type      DeliverableType      @default(REEL)
  status    DeliverableStatus    @default(PENDIENTE)
  dueDate   DateTime?
  project   Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  owner     User?                @relation("DeliverableOwner", fields: [ownerId], references: [id])
  ownerId   String?
  // Responsable de la revisión interna (a quien se "taguea" al subir el material): puede
  // pre-aprobar/solicitar cambios aunque no sea responsable del proyecto. Solo miembros.
  reviewer   User?  @relation("DeliverableReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewerId String?
  // Co-revisores: VARIAS personas pueden pre-aprobar el mismo entregable. `reviewerId` se conserva
  // como revisor "primario" (compat/visualización); el conjunto completo vive en `reviewers`.
  reviewers  DeliverableReviewer[]
  // Portada (thumbnail/poster) del REEL: imagen que acompaña al video entregado. Una productora
  // entrega el video y SU portada; aquí se sube/gestiona. Apunta a un FileAsset local del NAS
  // (servido por /api/files-asset, con miniatura WebP). SetNull si el archivo se borra.
  coverFileAsset   FileAsset? @relation("DeliverableCover", fields: [coverFileAssetId], references: [id], onDelete: SetNull)
  coverFileAssetId String?
  versions  DeliverableVersion[]
  // Fotos del entregable cuando type = FOTOGRAFIA (galería de selección del cliente).
  photos    DeliverablePhoto[]
  tasks     Task[]
  reviewComments ReviewComment[]
  decisions DeliverableDecision[]
  // Enlace de revisión del cliente: único por entregable, con visitas y revocación.
  reviewVisits        Int       @default(0)
  reviewRevokedAt     DateTime? // si está puesto, el portal del cliente queda inválido
  // Caducidad opcional del enlace del cliente. NULL = sin caducidad (no expira).
  reviewExpiresAt     DateTime?
  reviewAllowDrawings Boolean   @default(false) // habilita el modo dibujos/anotación
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([projectId])
  @@index([reviewerId])
  // El conteo del layout y marcebot filtran entregables por estado.
  @@index([status])
}

// Co-revisores de un entregable: VARIAS personas que pueden pre-aprobar/solicitar cambios en la
// revisión interna. Es aditivo al `reviewerId` (primario). Cualquiera del conjunto puede decidir y
// a todos les aparece en su bandeja «Proyectos a revisar».
model DeliverableReviewer {
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  deliverableId String
  user          User        @relation("DeliverableReviewers", fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  createdAt     DateTime    @default(now())

  @@id([deliverableId, userId])
  @@index([userId])
}

// Una foto dentro de un entregable de tipo FOTOGRAFIA. La fuente puede ser un archivo LOCAL
// del NAS (fileAsset, con miniatura vía sharp) o un enlace de Drive/URL (url). El cliente, desde
// el portal de revisión (sin login), marca cada foto: me gusta / no me gusta / pendiente, con un
// comentario opcional. El equipo ve el resultado y filtra por selección.
model DeliverablePhoto {
  id            String      @id @default(cuid())
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  deliverableId String
  // Fuente LOCAL (NAS): el archivo se sirve por /api/files-asset (full + ?preview para miniatura).
  fileAsset     FileAsset?  @relation("PhotoFile", fields: [fileAssetId], references: [id], onDelete: Cascade)
  fileAssetId   String?
  // Fuente ENLACE: imagen de Google Drive u otra URL directa (sin subir al NAS).
  url           String?
  filename      String // nombre visible de la foto
  position      Int         @default(0) // orden en la galería
  // Selección del cliente.
  pick          PhotoPick   @default(PENDIENTE)
  clientNote    String? // comentario opcional del cliente para esta foto
  pickedAt      DateTime? // cuándo la marcó por última vez
  createdAt     DateTime    @default(now())

  @@index([deliverableId])
}

enum PhotoPick {
  PENDIENTE
  ME_GUSTA
  NO_ME_GUSTA
}

// ─────────────────────────────────────────────
// Revisión de cliente (fase 5): portal público + comentarios con timestamp
// ─────────────────────────────────────────────

// Biblioteca de medios reutilizables del equipo (fase 5): música, logos, stock, plantillas…
model LibraryAsset {
  id           String   @id @default(cuid())
  name         String
  kind         FileKind @default(LINK)
  url          String?
  category     String? // "Música", "Logos", "Stock", "Plantillas"…
  uploadedBy   User?    @relation("LibraryUploader", fields: [uploadedById], references: [id])
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([category])
}

model ReviewComment {
  id            String      @id @default(cuid())
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  deliverableId String
  versionNumber Int? // versión del entregable a la que se refiere
  authorName    String // nombre mostrado (cliente sin cuenta, o nombre del miembro del equipo)
  // Si el comentario lo hizo un miembro del equipo con sesión, queda atribuido a su
  // usuario (para auditoría y avatar); null cuando lo escribe el cliente desde el portal.
  author        User?       @relation("ReviewCommentAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  authorUserId  String?
  body          String
  timecode      Float? // segundos dentro del video, si aplica
  drawingData   Json? // anotación/dibujo sobre un fotograma (trazos + captura), modo dibujos
  // Nota general: comentario suelto SIN captura de pantalla ni timecode (sección «Notas»).
  isNote        Boolean     @default(false)
  resolved      Boolean     @default(false)
  fromClient    Boolean     @default(true) // true = cliente; false = comentario del equipo (revisión interna)
  // Bloqueo: mientras es NULL el comentario interno es un borrador editable/borrable en el
  // workspace de pre-aprobación. Al «Solicitar cambios» se sella (queda inmutable) y es lo
  // que llega como checklist a la pestaña de Entregables.
  lockedAt      DateTime?
  createdAt     DateTime    @default(now())

  @@index([deliverableId, createdAt])
  @@index([authorUserId])
}

model DeliverableVersion {
  id            String      @id @default(cuid())
  number        Int
  notes         String?
  fileUrl       String? // enlace externo (Drive, etc.)
  fileAsset     FileAsset?  @relation("VersionFile", fields: [fileAssetId], references: [id], onDelete: SetNull)
  fileAssetId   String? // archivo subido al storage (para el portal del cliente)
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  deliverableId String
  uploadedBy    User?       @relation("VersionUploader", fields: [uploadedById], references: [id])
  uploadedById  String?
  // Compuerta de pre-aprobación interna: una versión solo llega al cliente cuando
  // el equipo la aprueba internamente (bloqueante).
  internalApproved   Boolean   @default(false)
  internalApprovedAt DateTime?
  createdAt     DateTime    @default(now())

  @@unique([deliverableId, number])
}

// Registro de decisiones de aprobación (pre-aprobación interna y revisión del cliente).
enum DecisionStage {
  INTERNA // pre-aprobación del equipo
  CLIENTE // revisión del cliente
}

enum DecisionResult {
  APROBADO
  CAMBIOS // se solicitaron cambios
}

model DeliverableDecision {
  id            String         @id @default(cuid())
  deliverable   Deliverable    @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  deliverableId String
  versionNumber Int? // versión a la que aplica la decisión
  stage         DecisionStage
  result        DecisionResult
  by            User?          @relation("DecisionAuthor", fields: [byUserId], references: [id], onDelete: SetNull)
  byUserId      String? // null si fue el cliente desde el enlace público
  byName        String? // nombre mostrado (cliente sin cuenta)
  note          String?
  createdAt     DateTime       @default(now())

  @@index([deliverableId, createdAt])
}

// ─────────────────────────────────────────────
// Archivos y carpetas
// ─────────────────────────────────────────────

enum FileKind {
  LOCAL
  DRIVE
  LINK
  NAS // ruta SMB del NAS para copiar/pegar en el explorador (\\servidor\carpeta)
}

// Archivo/referencia a NIVEL DE CLIENTE (ligero): enlaces (Drive/web) y rutas de red SMB
// (\\NAS\carpeta) que aplican al cliente, no a un proyecto puntual. No sube binarios al NAS
// (eso vive en los proyectos); aquí solo se guardan referencias para copiar/abrir.
model ClientFile {
  id           String   @id @default(cuid())
  name         String
  kind         FileKind @default(LINK) // LINK | DRIVE | NAS
  url          String? // enlace externo / Google Drive
  path         String? // ruta SMB \\servidor\carpeta (kind = NAS)
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId     String
  uploadedBy   User?    @relation("ClientFileUploader", fields: [uploadedById], references: [id])
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([clientId])
}

model ProjectFolder {
  id        String      @id @default(cuid())
  name      String // "01 Brief"
  icon      String? // emoji opcional para identificar la carpeta
  color     String? // color (token) para segmentar visualmente
  position  Int         @default(0)
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  files     FileAsset[]

  @@unique([projectId, name])
}

model FileAsset {
  id           String         @id @default(cuid())
  name         String
  kind         FileKind       @default(LINK)
  url          String? // link externo / Google Drive
  path         String? // ruta local en el storage del NAS
  mime         String?
  size         Int?
  version      Int            @default(1)
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  folder       ProjectFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  folderId     String?
  uploadedBy   User?          @relation("FileUploader", fields: [uploadedById], references: [id])
  uploadedById String?
  deliverableVersions DeliverableVersion[] @relation("VersionFile")
  // Fotos de entregables FOTOGRAFIA cuya fuente es este archivo local del NAS.
  deliverablePhotos   DeliverablePhoto[]   @relation("PhotoFile")
  // Entregables (REEL) que usan este archivo como imagen de portada.
  deliverableCovers   Deliverable[]        @relation("DeliverableCover")
  createdAt    DateTime       @default(now())

  @@index([projectId])
  @@index([folderId])
}

// ─────────────────────────────────────────────
// Plantillas de proyecto
// ─────────────────────────────────────────────

model ProjectTemplate {
  id          String      @id @default(cuid())
  key         String      @unique
  name        String
  description String?
  emoji       String?
  type        ProjectType @default(REEL)
  content     Json // { stages, folders, tasks[], deliverables[] }
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ─────────────────────────────────────────────
// Equipos: kits y planes de equipo por proyecto
// Conectado al inventario de la Wiki (tabla sys:inventario): cada "equipo" es una fila
// (DataRow) de esa tabla. Aquí vive lo que el inventario genérico no resuelve: kits
// guardados, reservas por fecha de grabación y disponibilidad por cantidad.
// ─────────────────────────────────────────────

// Kit guardado = conjunto con nombre de equipos del inventario (ej. "Kit Reels").
// Se puede soltar en un proyecto de un clic para precargar el checklist.
model EquipmentKit {
  id          String             @id @default(cuid())
  name        String             @unique
  emoji       String?
  description String?
  items       EquipmentKitItem[]
  createdBy   User?              @relation("KitCreator", fields: [createdById], references: [id])
  createdById String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model EquipmentKitItem {
  id       String       @id @default(cuid())
  kit      EquipmentKit @relation(fields: [kitId], references: [id], onDelete: Cascade)
  kitId    String
  // Equipo = fila del inventario (sys:inventario).
  row      DataRow      @relation(fields: [rowId], references: [id], onDelete: Cascade)
  rowId    String
  quantity Int          @default(1)

  @@unique([kitId, rowId])
  @@index([rowId])
}

// Plan de equipo para una grabación: proyecto + fecha. Lleva un responsable opcional y,
// si se asigna, una tarea espejo (aparece en "Mis tareas" de esa persona).
model EquipmentPlan {
  id          String                 @id @default(cuid())
  project     Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  title       String? // ej. "Grabación reels — locación norte"
  shootDate   DateTime // día de la grabación (se guarda a las 12:00 UTC, granularidad de día)
  status      String                 @default("planeando") // planeando | listo | entregado | devuelto
  assignee    User?                  @relation("EquipPlanAssignee", fields: [assigneeId], references: [id])
  assigneeId  String?
  // Tarea espejo opcional (responsable la ve en "Mis tareas"); se borra el vínculo si se elimina la tarea.
  task        Task?                  @relation("EquipPlanTask", fields: [taskId], references: [id], onDelete: SetNull)
  taskId      String?                @unique
  createdBy   User?                  @relation("EquipPlanCreator", fields: [createdById], references: [id])
  createdById String?
  items       EquipmentReservation[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([projectId])
  @@index([shootDate])
  @@index([assigneeId])
}

// Reserva de un equipo (fila del inventario) dentro de un plan, con cantidad y estado.
model EquipmentReservation {
  id        String        @id @default(cuid())
  plan      EquipmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId    String
  row       DataRow       @relation(fields: [rowId], references: [id], onDelete: Cascade)
  rowId     String
  quantity  Int           @default(1)
  packed    Boolean       @default(false) // marcado en el checklist como listo/empacado
  note      String?
  createdAt DateTime      @default(now())

  @@unique([planId, rowId])
  @@index([rowId])
  // Disponibilidad por fecha: se cruza con shootDate del plan.
  @@index([planId])
}

// "Mi día": lista de enfoque PERSONAL del usuario (planificador estilo Sunsama/Things).
// Una tarea puede pertenecer a dos personas (dueño y responsable), así que el día es por
// usuario — no un campo en Task. `position` ordena la lista; al completar la tarea, sale
// del listado abierto y deja de aparecer en Mi día.
model MyDayItem {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, taskId])
  @@index([userId])
  @@index([taskId])
}
