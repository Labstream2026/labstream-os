    "@prisma/client": "^6.19.3",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-slot": "^1.2.5",
    "@tanstack/react-table": "^8.21.3",
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.11",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
